# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values before running locally.
# .env.local is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# The publicly-accessible Google Sheet ID used as the CMS.
# The sheet must be published / shared as "Anyone with the link can view".
# Used in: lib/googleSheets.ts  (reads Menu, Hours, Contact, SignatureItem tabs)
# How to find: open the sheet → copy the ID from the URL
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
NEXT_PUBLIC_GOOGLE_SHEET_ID=

# The canonical URL of the deployed site (no trailing slash).
# Used in: app/layout.tsx (OG/Twitter meta), app/sitemap.ts, app/robots.ts
# Local dev example: http://localhost:3000
# Production example: https://kavehammersmith.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
